# ============================================================
# DM Panda - Root Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Port Configuration ---
PORT=5000                         # Backend API port
FRONTEND_PORT=5173                # Frontend static server port
ADMIN_PORT=5174                   # Admin panel static server port

# --- CORS / Origins ---
FRONTEND_ORIGIN=https://your-frontend-domain.com
ADMIN_PANEL_ORIGIN=https://your-admin-domain.com

# --- Appwrite ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key

# --- Instagram / Meta ---
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# --- Payment (Razorpay) ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- Frontend Build (set these in Frontend/.env) ---
# VITE_API_BASE_URL=https://your-backend-domain.com

# --- Email Change ---
# EMAIL_CHANGE_TOKEN_EXPIRY_MINUTES=60  # How long email change verification links are valid (default: 60)
