# ============================================================
# Backend API - Environment Variables
# Rename this file to .env and fill in real values.
# ============================================================

PORT=3000

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_STORAGE_ID=your_storage_id

# CORS Origins (your actual subdomains)
FRONTEND_ORIGIN=https://app.yourdomain.com
ADMIN_PANEL_ORIGIN=https://admin.yourdomain.com
BACKEND_PUBLIC_ORIGIN=https://api.yourdomain.com

# Instagram / Meta App
INSTAGRAM_APP_ID=your_meta_app_id
INSTAGRAM_APP_SECRET=your_meta_app_secret
INSTAGRAM_APP_VERSION=v24.0
INSTAGRAM_REDIRECT_URL=https://app.yourdomain.com/auth/ig-callback
INSTAGRAM_AUTH_URL=https://www.instagram.com/oauth/authorize?force_reauth=true&client_id=YOUR_APP_ID&redirect_uri=https://app.yourdomain.com/auth/ig-callback&response_type=code&scope=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments,instagram_business_content_publish,instagram_business_manage_insights

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Appwrite Function Names
FUNCTION_REMOVE_INSTAGRAM=remove-instagram
