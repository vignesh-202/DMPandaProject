# ============================================================
# Frontend - Environment Variables
# Rename this file to .env and fill in real values BEFORE building.
# These are build-time variables (VITE_ prefix), baked into dist/.
# ============================================================

# URL of your Backend API (your api.yourdomain.com subdomain)
VITE_API_BASE_URL=https://api.yourdomain.com

# Razorpay public key (for payment integration)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
