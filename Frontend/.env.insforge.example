# Insforge Configuration
# Copy this to .env and fill in your values

# Insforge Backend URL
VITE_INSFORGE_BASE_URL=https://kkqnp7i4.ap-southeast.insforge.app

# Insforge Anonymous Key (for public/unauthenticated requests)
# Get this from: user-insforge-get-anon-key MCP tool
VITE_INSFORGE_ANON_KEY=your-anon-key-here

# Keep existing variables for Flask backend
VITE_API_BASE_URL=https://api.dmpanda.com

# Feature flag to toggle between Appwrite and Insforge
# Set to 'insforge' to use Insforge, 'appwrite' to use Appwrite
VITE_AUTH_PROVIDER=appwrite
