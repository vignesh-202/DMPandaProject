# ============================================================
# Streamer Node - Environment Variables
# Rename this file to .env and fill in real values.
# ============================================================

PORT=3000

# Meta webhook verification token (must match what you set in Meta Developer Console)
META_VERIFY_TOKEN=your_meta_webhook_verify_token

# Shared secret between streamer and worker (generate a long random string)
WORKER_SHARED_SECRET=your_long_random_shared_secret

# Timeouts (milliseconds)
STREAMER_ASSIGN_TIMEOUT_MS=3000
STREAMER_JOB_HEARTBEAT_TIMEOUT_MS=30000
STREAMER_TIMEOUT_SWEEP_MS=2000
STREAMER_MAX_JOB_ATTEMPTS=5
