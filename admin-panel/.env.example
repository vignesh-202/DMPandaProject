# ============================================================
# Admin Panel - Environment Variables (Build-time)
# Rename this file to .env and fill in real values BEFORE building.
# These are VITE_ build-time variables, baked into dist/.
# ============================================================

# Appwrite (same instance as Backend)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id

# Backend API URL (your api.yourdomain.com)
VITE_API_BASE_URL=https://api.yourdomain.com
